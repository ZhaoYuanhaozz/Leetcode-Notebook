   "source": [
    "返回升序排序后数组的下标，却不改变原本数组的排列方式。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "原数组：[1, 11, 4, 23]\n",
      "数组下标：[0, 2, 1, 3]\n"
     ]
    }
   ],
   "source": [
    "nums1 = [1,11,4,23]\n",
    "n = len(nums1)\n",
    "idx1 = list(range(n))\n",
    "# 对数组下标排序\n",
    "idx1.sort(key=lambda x: nums1[x])\n",
    "print('原数组：{}'.format(nums1))\n",
    "print('数组下标：{}'.format(idx1))\n"
   ]
  }
 ],
